{% if caddy_mode == "prod" %}
{
    email {{ caddy_email }}
    # Use acme_dns / acme_http_challenge options here if needed
}
{% endif %}

#
# === Test environment (rosy) ===
#
{% if caddy_mode == "dev" %}
# Rosy Test Server (internal TLS)
app.rosy.home.org, api.rosy.home.org, fasnacht.rosy.home.org, graphdb.rosy.home.org {
    tls internal

    @app host app.rosy.home.org
    handle @app {
        reverse_proxy oldap-app:3000
    }

    @api host api.rosy.home.org
    handle @api {
        reverse_proxy oldap-api:8000
    }

    @fasnacht host fasnacht.rosy.home.org
    handle @fasnacht {
        reverse_proxy fasnachts-page:3100
    }

    @graphdb host graphdb.rosy.home.org
    handle @graphdb {
        # Protect GraphDB Workbench with HTTP Basic Auth
        basicauth {
            {env.GRAPHDB_BASIC_USER} {env.GRAPHDB_BASIC_HASH}
        }
        reverse_proxy graphdb:7200
    }
}
{% endif %}

#
# === Production environment (Let’s Encrypt) ===
#
{% if caddy_mode == "prod" %}
# API
api.oldap.org {
    # Preflight CORS
    @apiCors method OPTIONS
    handle @apiCors {
        header Access-Control-Allow-Origin *
        header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        header Access-Control-Allow-Headers "Authorization, Content-Type"
        respond "" 204
    }

    # Proxy normal API requests
    reverse_proxy oldap-api:8000 {
        # forward Authorization header upstream (Flask needs it)
        header_up Authorization {http.request.header.Authorization}
    }
}

# GraphDB (protected)
graphdb.oldap.org {
    encode gzip zstd

    # Protect GraphDB Workbench with HTTP Basic Auth
    basicauth {
        {env.GRAPHDB_BASIC_USER} {env.GRAPHDB_BASIC_HASH}
    }

    reverse_proxy graphdb:7200
}

# SPA / App
app.oldap.org {
    encode gzip zstd
    reverse_proxy oldap-app:3000
}

# Fasnacht page (two domains possible)
fasnacht.digital, fasnacht.oldap.org {
    encode gzip zstd
    reverse_proxy fasnachts-page:3100
}
{% endif %}