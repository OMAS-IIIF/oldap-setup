# --- Caddyfile Template ---
{% if caddy_mode == "dev" %}
{
    auto_https disable_redirects
}
{% elif caddy_mode == "prod" %}
{
    email {{ caddy_email }}
}
{% endif %}


# Development / Local setup with HTTPS
{% if caddy_mode == "dev" %}
# Shared routes for Rosy, imported by both HTTP and local HTTPS.
(rosy_test_routes) {
    @app host app.rosy.home.org
    handle @app {
        reverse_proxy oldap-app:3000
    }

    @api host api.rosy.home.org
    handle @api {
        reverse_proxy oldap-api:8000
    }

    @fasnacht host fasnacht.rosy.home.org
    handle @fasnacht {
        reverse_proxy fasnachts-page:3100
    }

    @graphdb host graphdb.rosy.home.org
    handle @graphdb {
        # Protect GraphDB Workbench with HTTP Basic Auth
        basicauth {
            {env.GRAPHDB_BASIC_USER} {env.GRAPHDB_BASIC_HASH}
        }
        reverse_proxy graphdb:7200
    }
}

# Rosy Test Server (HTTP)
http://app.rosy.home.org, http://api.rosy.home.org, http://fasnacht.rosy.home.org, http://graphdb.rosy.home.org {
    import rosy_test_routes
}

# Rosy Test Server (local HTTPS)
https://app.rosy.home.org, https://api.rosy.home.org, https://fasnacht.rosy.home.org, https://graphdb.rosy.home.org {
    tls internal
    import rosy_test_routes
}
{% endif %}

# Production setup (HTTPS, handled by Caddy)
{% if caddy_mode == "prod" %}
app.oldap.org {
    reverse_proxy oldap-app:3000
